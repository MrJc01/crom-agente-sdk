{
  "name": "crom-agente-sdk",
  "version": "0.1.1-alpha.1",
  "description": "SDK oficial em TypeScript para integração com o ecossistema crom-agente",
  "type": "module",
  "main": "./dist/crom-agente-sdk.umd.cjs",
  "module": "./dist/crom-agente-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/crom-agente-sdk.js",
      "require": "./dist/crom-agente-sdk.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "docs": "typedoc"
  },
  "keywords": [
    "crom",
    "agente",
    "sdk",
    "typescript"
  ],
  "author": "CromIA",
  "license": "CUSTOM",
  "peerDependencies": {
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-fs": "^2.0.0",
    "@tauri-apps/plugin-os": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@tauri-apps/api": {
      "optional": true
    },
    "@tauri-apps/plugin-fs": {
      "optional": true
    },
    "@tauri-apps/plugin-os": {
      "optional": true
    },
    "@tauri-apps/plugin-shell": {
      "optional": true
    }
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^1.6.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-dts": "^3.7.3",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "ws": "^8.21.0"
  }
}
