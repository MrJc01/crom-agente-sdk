{
  "name": "crom-agente-sdk",
  "version": "0.1.1-alpha.1",
  "description": "SDK oficial em TypeScript para integração com o ecossistema crom-agente",
  "type": "module",
  "main": "./dist/crom-agente-sdk.umd.cjs",
  "module": "./dist/crom-agente-sdk.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/crom-agente-sdk.js",
      "require": "./dist/crom-agente-sdk.umd.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs": "typedoc"
  },
  "keywords": [
    "crom",
    "agente",
    "sdk",
    "typescript"
  ],
  "author": "CromIA",
  "license": "CUSTOM",
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "typedoc": "^0.28.19",
    "typescript": "^5.3.3",
    "vite": "^5.1.4",
    "vite-plugin-dts": "^3.7.3",
    "vitest": "^1.3.1"
  },
  "dependencies": {
    "axios": "^1.18.0",
    "ws": "^8.21.0"
  }
}
